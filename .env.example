# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── Webhook (leave empty for polling mode) ───────────
WEBHOOK_HOST=
WEBHOOK_PATH=/webhook/telegram
WEBHOOK_PORT=8443

# ── Database (Postgres) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://diary:diary@localhost:5432/diarybot

# ── Redis (future queue) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── STT (AssemblyAI) ─────────────────────────────────
ASSEMBLYAI_API_KEY=your_assemblyai_key

# ── LLM — OpenAI ────────────────────────────────────
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o

# ── LLM — Gemini ────────────────────────────────────
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.0-flash

# ── Active providers ─────────────────────────────────
STT_PROVIDER=assemblyai
LLM_PROVIDER=gemini

# ── LLM tuning ──────────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Voice limits ─────────────────────────────────────
MAX_VOICE_DURATION_SECONDS=300

# ── Admin (comma-separated Telegram user IDs) ───────
ADMIN_TG_USER_IDS=123456789

# ── Encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# ── Mini App URL ─────────────────────────────────────
MINI_APP_URL=https://your-domain.com/admin-app

# ── Defaults ─────────────────────────────────────────
DEFAULT_TIMEZONE=Asia/Dubai
DEFAULT_LOCALE=ru
LOG_LEVEL=INFO

# ── Trial limits ─────────────────────────────────────
TRIAL_ENTRIES_PER_DAY=5
TRIAL_STT_SECONDS_PER_DAY=300
